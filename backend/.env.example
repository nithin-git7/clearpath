# Runtime
APP_ENV=development

# Browser origins allowed by FastAPI CORS in local development (comma-separated)
FRONTEND_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3002,http://127.0.0.1:3002

# Provider-neutral LLM configuration (used from Section 7)
LLM_PROVIDER=
LLM_MODEL=
LLM_API_BASE_URL=
LLM_API_KEY=

# Reserved for Supabase persistence in Section 18
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

